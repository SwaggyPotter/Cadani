---
import '@styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Cadani Solar',
  description = 'Solarloesungen fuer Berlin und Brandenburg.',
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
