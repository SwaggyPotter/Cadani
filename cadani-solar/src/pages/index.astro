---
import BaseLayout from '@layouts/BaseLayout.astro';
import CompanyIntroSection from '@components/sections/CompanyIntroSection.astro';
import FamilyBusinessSection from '@components/sections/FamilyBusinessSection.astro';
import FundingSection from '@components/sections/FundingSection.astro';
import HeroSection from '@components/sections/HeroSection.astro';
import PartnerLogos from '@components/sections/PartnerLogos.astro';
import PrivateBusinessSection from '@components/sections/PrivateBusinessSection.astro';
import ProjectsSection from '@components/sections/ProjectsSection.astro';
import ReferencesGallery from '@components/sections/ReferencesGallery.astro';
import ServiceBenefitsSection from '@components/sections/ServiceBenefitsSection.astro';
import SolarInquirySection from '@components/sections/SolarInquirySection.astro';
import SolarProcessSection from '@components/sections/SolarProcessSection.astro';
import TibberPartnerSection from '@components/sections/TibberPartnerSection.astro';
import SeoContentPlaceholder from '@components/sections/SeoContentPlaceholder.astro';

const title = 'Startseite | Cadani Solar';
const description = 'Meta Description Platzhalter fuer die Startseite von Cadani Solar.';
---

<BaseLayout title={title} description={description}>
  <main id="main-content">
    <HeroSection />
    <PartnerLogos />
    <CompanyIntroSection />
    <ServiceBenefitsSection />
    <FamilyBusinessSection />
    <FundingSection />
    <SolarProcessSection />
    <ProjectsSection />
    <ReferencesGallery />
    <PrivateBusinessSection />
    <TibberPartnerSection />
    <SolarInquirySection />
    <SeoContentPlaceholder />
  </main>
</BaseLayout>
