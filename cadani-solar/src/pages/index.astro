---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroSection from '@components/sections/HeroSection.astro';
import PartnerLogos from '@components/sections/PartnerLogos.astro';
import SeoContentPlaceholder from '@components/sections/SeoContentPlaceholder.astro';

const title = 'Startseite | Cadani Solar';
const description = 'Meta Description Platzhalter fuer die Startseite von Cadani Solar.';
---

<BaseLayout title={title} description={description}>
  <main id="main-content">
    <HeroSection />
    <PartnerLogos />
    <SeoContentPlaceholder />
  </main>
</BaseLayout>
