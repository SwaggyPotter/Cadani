---
import BaseLayout from '@layouts/BaseLayout.astro';
import SeoContentPlaceholder from '@components/sections/SeoContentPlaceholder.astro';

export function getStaticPaths() {
  return [];
}

const { slug } = Astro.params;
const title = 'Referenz Detailseite | Cadani Solar';
const description = 'Meta Description Platzhalter fuer eine Referenz Detailseite.';
const h1 = `H1 Platzhalter Referenz: ${slug ?? 'slug'}`;
---

<BaseLayout title={title} description={description}>
  <main id="main-content">
    <article class="section" aria-labelledby="page-heading">
      <div class="container stack">
        <h1 id="page-heading">{h1}</h1>
        <p>Platzhalter fuer spaetere Referenzdetails.</p>
      </div>
    </article>

    <SeoContentPlaceholder label="SEO Content Referenz" />
  </main>
</BaseLayout>
