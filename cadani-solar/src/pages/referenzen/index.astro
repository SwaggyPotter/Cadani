---
import BaseLayout from '@layouts/BaseLayout.astro';
import SeoContentPlaceholder from '@components/sections/SeoContentPlaceholder.astro';

const title = 'Referenzen | Cadani Solar';
const description = 'Meta Description Platzhalter fuer Referenzen.';
const h1 = 'H1 Platzhalter Referenzen';
---

<BaseLayout title={title} description={description}>
  <main id="main-content">
    <section class="section" aria-labelledby="page-heading">
      <div class="container stack">
        <h1 id="page-heading">{h1}</h1>
        <p>Platzhalter fuer spaetere Referenzuebersicht.</p>
      </div>
    </section>

    <SeoContentPlaceholder />
  </main>
</BaseLayout>
