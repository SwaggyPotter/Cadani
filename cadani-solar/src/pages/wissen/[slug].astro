---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/ui/Button.astro';
import { formatNewsDate, getNewsPostBySlug, newsPosts } from '@data/news';
import { site } from '@data/site';

export function getStaticPaths() {
  return newsPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const post = Astro.props.post ?? getNewsPostBySlug(Astro.params.slug);
const title = post ? `${post.title} | Cadani Solar Ratgeber` : 'Wissen | Cadani Solar';
const description = post?.description ?? 'Ratgeberwissen zu Photovoltaik, Solaranlagen und Batteriespeichern.';
const canonical = post ? `${site.url}/wissen/${post.slug}` : undefined;
---

<BaseLayout title={title} description={description} canonical={canonical} image={post?.image} type="article">
  <main id="main-content">
    <article class="article-header" aria-labelledby="page-heading">
      <div class="article-layout article-shell">
        {
          post && (
            <p class="article-meta">
              <span>{post.category}</span>
              <time datetime={post.date}>{formatNewsDate(post.date)}</time>
            </p>
          )
        }
        <h1 id="page-heading">{post?.title ?? 'Wissen'}</h1>
        {post && <p class="article-lead">{post.description}</p>}
        {
          post && (
            <img
              class="article-image"
              src={post.image}
              alt={post.imageAlt}
              width="960"
              height="640"
              loading="eager"
              decoding="async"
            />
          )
        }
      </div>
    </article>

    <section class="section">
      <div class="article-layout article-content">
        <p>
          Der vollstaendige Ratgeberbeitrag wird derzeit fuer die neue Cadani Solar Webseite
          aufbereitet. Fuer eine konkrete Einschaetzung Ihrer Solaranlage, Ihres Batteriespeichers
          oder der passenden Planung in Berlin und Brandenburg koennen Sie direkt eine Beratung
          anfragen.
        </p>
        <div class="article-actions">
          <Button href="/check" label="Kostenlose Beratung anfragen" />
          <Button href="/news" label="Zurueck zur News-Uebersicht" variant="secondary" />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .article-lead {
    color: var(--color-text);
    font-size: var(--font-size-md);
  }

  .article-image {
    width: 100%;
    aspect-ratio: 3 / 2;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    object-fit: cover;
  }

  .article-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-block-start: var(--space-xl);
  }
</style>
