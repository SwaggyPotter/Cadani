---
import BaseLayout from '@layouts/BaseLayout.astro';
import SeoContentPlaceholder from '@components/sections/SeoContentPlaceholder.astro';

export function getStaticPaths() {
  return [];
}

const { ort } = Astro.params;
const title = 'Brandenburg Ort | Cadani Solar';
const description = 'Meta Description Platzhalter fuer eine Brandenburger Ortsseite.';
const h1 = `H1 Platzhalter Brandenburg: ${ort ?? 'ort'}`;
---

<BaseLayout title={title} description={description}>
  <main id="main-content">
    <section class="section" aria-labelledby="page-heading">
      <div class="container stack">
        <h1 id="page-heading">{h1}</h1>
        <p>Platzhalter fuer spaetere lokale SEO-Inhalte fuer Orte in Brandenburg.</p>
      </div>
    </section>

    <SeoContentPlaceholder label="SEO Content Brandenburg Ort" />
  </main>
</BaseLayout>
