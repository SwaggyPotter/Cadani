---
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import ContactCtaSection from '@components/sections/ContactCtaSection.astro';
import FaqSection from '@components/sections/FaqSection.astro';
import ReferencesPreview from '@components/sections/ReferencesPreview.astro';
import PageLayout from '@layouts/PageLayout.astro';
import { berlinRegions, type RegionLandingPage } from '@data/regions';

export function getStaticPaths() {
  return berlinRegions.map((region) => ({
    params: {
      stadtteil: region.slug,
    },
    props: {
      region,
    },
  }));
}

interface Props {
  region: RegionLandingPage;
}

const { region } = Astro.props;
const breadcrumbs = [
  { label: 'Regionen', href: '/regionen/' },
  { label: 'Berlin', href: '/regionen/berlin/' },
  { label: region.city },
];

const breadcrumbSchemaItems = [
  { label: 'Startseite', href: '/' },
  { label: 'Berlin', href: '/regionen/berlin/' },
  { label: region.city, href: region.href },
];
---

<PageLayout title={region.metaTitle} description={region.metaDescription} h1={region.h1} breadcrumbs={breadcrumbs}>
  <BreadcrumbSchema items={breadcrumbSchemaItems} />

  <section class="section" aria-labelledby="regional-content-heading">
    <div class="container stack">
      <h2 id="regional-content-heading">Regionale Informationen</h2>
      <p>{region.seoText}</p>
    </div>
  </section>

  <ReferencesPreview title={`Referenzen in ${region.city}`} references={region.references} />
  <FaqSection title={`Fragen zu Photovoltaik in ${region.city}`} items={region.faq} />
  <ContactCtaSection {...region.cta} />
</PageLayout>
