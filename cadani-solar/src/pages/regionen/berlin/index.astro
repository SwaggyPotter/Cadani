---
import BaseLayout from '@layouts/BaseLayout.astro';
import SeoContentPlaceholder from '@components/sections/SeoContentPlaceholder.astro';

const title = 'Region Berlin | Cadani Solar';
const description = 'Meta Description Platzhalter fuer die Region Berlin.';
const h1 = 'H1 Platzhalter Region Berlin';
---

<BaseLayout title={title} description={description}>
  <main id="main-content">
    <section class="section" aria-labelledby="page-heading">
      <div class="container stack">
        <h1 id="page-heading">{h1}</h1>
        <p>Platzhalter fuer spaetere lokale SEO-Uebersicht Berlin.</p>
      </div>
    </section>

    <SeoContentPlaceholder label="SEO Content Region Berlin" />
  </main>
</BaseLayout>
