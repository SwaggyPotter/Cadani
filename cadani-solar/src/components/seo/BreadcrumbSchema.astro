---
interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  items?: BreadcrumbItem[];
}

const { items = [] } = Astro.props;
const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    item: item.href,
  })),
};
---

{items.length > 0 && <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />}
