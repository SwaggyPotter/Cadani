---
interface Props {
  name: string;
  value: string;
  label: string;
  type?: 'radio' | 'checkbox';
  required?: boolean;
}

const { name, value, label, type = 'radio', required = false } = Astro.props;
---

<label class="option-card">
  <input type={type} name={name} value={value} required={required} />
  <span>{label}</span>
</label>
