---
import SolarInquiryForm from '@components/forms/SolarInquiryForm.astro';
---

<section class="solar-inquiry" id="kontakt" aria-labelledby="solar-inquiry-heading">
  <!-- TODO: Bild später lokal in public/images/backgrounds speichern und als WebP/AVIF optimieren -->
  <div class="solar-inquiry__overlay" aria-hidden="true"></div>

  <div class="container solar-inquiry__inner">
