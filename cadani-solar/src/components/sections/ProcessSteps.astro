---
interface Step {
  title: string;
  text?: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<ol class="process-steps">
  {
    steps.map((step, index) => (
      <li class="process-steps__item">
        <span class="process-steps__number">{String(index + 1).padStart(2, '0')}</span>
        <div>
          <h3>{step.title}</h3>
          {step.text && <p>{step.text}</p>}
        </div>
      </li>
    ))
  }
</ol>
