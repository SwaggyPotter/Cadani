---
import type { ProductCategory } from '@data/products';

interface Props {
  categories: ProductCategory[];
}

const { categories } = Astro.props;
---

<nav class="product-nav" aria-label="Produktkategorien">
  <div class="container product-nav__inner">
    {
      categories.map((category) => (
        <a class="product-nav__link" href={`#${category.id}`}>
          {category.label}
        </a>
      ))
    }
  </div>
</nav>

<style>
  .product-nav {
    position: sticky;
    inset-block-start: 4rem;
    z-index: 10;
    border-block: 1px solid var(--color-border);
    background: rgb(255 255 255 / 0.94);
    backdrop-filter: blur(10px);
  }

  .product-nav__inner {
    display: flex;
    gap: var(--space-sm);
    overflow-x: auto;
    padding-block: var(--space-sm);
    scrollbar-width: thin;
  }

  .product-nav__link {
    display: inline-flex;
    min-height: 2.5rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    padding-inline: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: var(--color-white);
    color: var(--color-text);
    font-size: var(--font-size-sm);
    font-weight: 800;
    text-decoration: none;
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      color 160ms ease;
  }

  .product-nav__link:hover,
  .product-nav__link:focus-visible {
    border-color: rgb(31 157 122 / 0.36);
    background: rgb(31 157 122 / 0.08);
    color: var(--color-success);
  }

  @media (min-width: 48rem) {
    .product-nav {
      inset-block-start: 4.75rem;
    }

    .product-nav__inner {
      flex-wrap: wrap;
      justify-content: center;
      overflow: visible;
    }
  }
</style>

